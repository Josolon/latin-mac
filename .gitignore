.DS_Store

# Ignore the heavy SQLite databases (rebuilt by scripts/, not committed)
data/ls.db
data/morph.db
data/synonyms.db
data/grammar.db

# Ignore the massive Perseus Lewis & Short TEI-XML source
data/lewis_short/

# Ignore the Diogenes-packaged Morpheus full-form analyses
data/analyses/

# Ignore the Perseus Allen & Greenough TEI-XML source
data/allen_greenough/

# Ignore the Morpheus engine checkout (cloned by scripts/, not committed)
data/morpheus/

# Ignore raw Ramshorn OCR text / archive.org downloads
data/ramshorn/

# Ignore raw Doederlein text / Project Gutenberg downloads
data/doederlein/

# Ignore Apple Dictionary Development Kit build artifacts
src/objects/
src/*.dictionary

# Ignore the generated dictionary source XML (large, regenerated by build scripts)
src/LatinDictionary.xml
